<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- AJIO Inspired Success Icon Container -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="120dp"
        android:layout_height="120dp"
        app:cardCornerRadius="60dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#F8FAFC"
        android:layout_marginBottom="32dp">
        
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:src="@android:drawable/checkbox_on_background"
            app:tint="#2C4152" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CONGRATULATIONS!"
        android:textColor="#2C4152"
        android:textSize="22sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.1"
        android:gravity="center" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Order Placed Successfully"
        android:textColor="#1E293B"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvOrderNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="ORDER ID: #CLOTH-82734"
        android:textColor="#94A3B8"
        android:textSize="13sp"
        android:letterSpacing="0.05" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="You can now view your order history and track its status in the 'My Orders' section."
        android:textColor="#64748B"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F1F5F9"
        android:layout_marginVertical="40dp" />

    <!-- VIEW ORDER Button: AJIO Teal -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnViewOrder"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:text="VIEW ORDER"
        android:textAllCaps="true"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:cornerRadius="12dp"
        android:backgroundTint="#2C4152"
        android:elevation="4dp"
        android:letterSpacing="0.1" />

    <!-- CONTINUE SHOPPING Button: White/Outline -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBackToHome"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginTop="12dp"
        android:text="CONTINUE SHOPPING"
        android:textColor="#2C4152"
        android:textAllCaps="true"
        android:textStyle="bold"
        android:letterSpacing="0.1" />

</LinearLayout>
