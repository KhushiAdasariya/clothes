<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/headerTrack"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:padding="4dp"
            android:rotation="180"
            android:src="@drawable/arrow"
            app:tint="#1A237E" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:layout_toEndOf="@id/btnBack"
            android:text="Track Order"
            android:textColor="#1A237E"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerTrack"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Order Basic Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvTrackOrderId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Order ID: #CLOTH-82734"
                        android:textColor="#1E293B"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTrackEstDelivery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Est. Delivery: 31 March, 2024"
                        android:textColor="#10B981"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Timeline Tracking Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:paddingStart="8dp">

                <!-- Vertical Line -->
                <View
                    android:layout_width="2dp"
                    android:layout_height="300dp"
                    android:layout_marginStart="11dp"
                    android:layout_marginTop="10dp"
                    android:background="#E2E8F0" />

                <!-- Steps -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Step 1: Placed -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <View
                            android:id="@+id/dotPlaced"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@drawable/circle_bg"
                            android:backgroundTint="#1A237E" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/dotPlaced"
                            android:layout_marginStart="20dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Order Placed"
                                android:textColor="#1E293B"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="We have received your order"
                                android:textColor="#64748B"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </RelativeLayout>

                    <!-- Step 2: Processing -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="40dp">
                        <View
                            android:id="@+id/dotProcessing"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@drawable/circle_bg"
                            android:backgroundTint="#E2E8F0" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/dotProcessing"
                            android:layout_marginStart="20dp"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvStepProcessing"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Processing"
                                android:textColor="#94A3B8"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Your order is being prepared"
                                android:textColor="#94A3B8"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </RelativeLayout>

                    <!-- Step 3: Shipped -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="40dp">
                        <View
                            android:id="@+id/dotShipped"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@drawable/circle_bg"
                            android:backgroundTint="#E2E8F0" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/dotShipped"
                            android:layout_marginStart="20dp"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvStepShipped"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Shipped"
                                android:textColor="#94A3B8"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="On the way to your destination"
                                android:textColor="#94A3B8"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </RelativeLayout>

                    <!-- Step 4: Delivered -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="40dp">
                        <View
                            android:id="@+id/dotDelivered"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@drawable/circle_bg"
                            android:backgroundTint="#E2E8F0" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/dotDelivered"
                            android:layout_marginStart="20dp"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvStepDelivered"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Delivered"
                                android:textColor="#94A3B8"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Order successfully delivered"
                                android:textColor="#94A3B8"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </RelativeLayout>

                </LinearLayout>
            </RelativeLayout>

            <!-- Need Help Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F1F5F9">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_call"
                        app:tint="#1A237E" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Need help with your order?"
                            android:textColor="#1E293B"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Contact support for any queries"
                            android:textColor="#64748B"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</RelativeLayout>
