<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:orientation="vertical"
    tools:context=".manage_order">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/headerManageOrder"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:padding="4dp"
            android:rotation="180"
            android:src="@drawable/arrow"
            app:tint="#1A237E" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:layout_toEndOf="@id/btnBack"
            android:text="Customer Orders"
            android:textColor="#1A237E"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium" />
    </RelativeLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvManageOrders"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="8dp"
        tools:listitem="@layout/item_manage_order" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/layoutNoOrders"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="40dp">
        <ImageView 
            android:layout_width="120dp" 
            android:layout_height="120dp" 
            android:src="@android:drawable/ic_menu_agenda" 
            app:tint="#E2E8F0"/>
        <TextView 
            android:layout_width="wrap_content" 
            android:layout_height="wrap_content" 
            android:text="No orders placed yet" 
            android:textColor="#1E293B" 
            android:textSize="18sp" 
            android:textStyle="bold" 
            android:layout_marginTop="24dp"/>
    </LinearLayout>

</LinearLayout>
